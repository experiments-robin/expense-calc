// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId} (matches auth.uid)
// Fields:
//   - uid: string (required)
//   - displayName: string (optional)
//   - email: string (required)
//   - photoURL: string (optional)
//   - createdAt: timestamp (optional)
//
// Collection: groups
// Document ID: {groupId}
// Fields:
//   - id: string (optional)
//   - name: string (required, 1-100 chars)
//   - description: string (optional, 0-500 chars)
//   - createdBy: string (required, matches auth.uid)
//   - createdAt: timestamp (required)
//   - type: string (required, enum: personal, household, trip, other)
//   - memberIds: list (required, strings of UIDs)
//   - maxBudget: number (optional, positive)
//   - budgetType: string (optional, enum: weekly, monthly, total)
//
// Collection: groups/{groupId}/expenses
// Document ID: {expenseId}
// Fields:
//   - id: string (optional)
//   - amount: number (required, positive)
//   - description: string (required, 1-200 chars)
//   - category: string (required)
//   - paidBy: string (required, matches a member UID)
//   - date: timestamp (required)
//   - createdAt: timestamp (required)
//   - splitType: string (optional, enum: equal, percentage, exact)
//
// Collection: groups/{groupId}/members
// Document ID: {userId}
// Fields:
//   - uid: string (required, matches auth.uid)
//   - role: string (required, enum: admin, member)
//   - joinedAt: timestamp (required)
//   - displayName: string (optional)
//   - email: string (optional)
//
// ===============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // Auth tokens NEVER contain custom claims in this environment.
    // We look up roles in the group members subcollection.
    function isGroupAdmin(groupId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    function isMember(data) {
      return isSignedIn() && request.auth.uid in data.get('memberIds', []);
    }

    function isGroupMember(groupId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/groups/$(groupId)) && 
             request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.get('memberIds', []);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (data.categoryLimits == null || data.categoryLimits is map) &&
             data.createdAt == request.time;
    }

    function isValidSubscription(data) {
      return data.name in ["Netflix", "Spotify", "Amazon Prime", "Gym Membership", "Internet Bill", "Mobile Plan", "Apple One", "Disney+", "Hulu", "YouTube Premium", "Xbox Game Pass", "PlayStation Plus", "Creative Cloud", "Office 365", "Other"] &&
             data.amount is number && data.amount > 0 &&
             data.cycle in ['weekly', 'monthly', 'yearly'] &&
             data.nextBillingDate is timestamp &&
             data.category is string &&
             data.active is bool &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidSavingsGoal(data) {
      return data.name in ["Emergency Fund", "Vacation", "New Car", "House Downpayment", "Wedding", "Laptop", "Phone", "Education", "Retirement", "Investment", "Gift", "Furniture", "Other"] &&
             data.targetAmount is number && data.targetAmount > 0 &&
             data.currentAmount is number && data.currentAmount >= 0 &&
             (data.deadline == null || data.deadline is timestamp) &&
             data.color is string &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidGroup(data) {
      return data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.createdBy == request.auth.uid &&
             data.type in ['personal', 'household', 'trip', 'other'] &&
             data.memberIds is list && data.memberIds.size() >= 1 && data.memberIds.size() <= 50 &&
             data.memberIds[0] is string &&
             data.createdAt == request.time &&
             (data.description == null || (data.description is string && data.description.size() <= 500)) &&
             (data.maxBudget == null || (data.maxBudget is number && data.maxBudget >= 0)) &&
             (data.budgetType == null || data.budgetType in ['weekly', 'monthly', 'total']);
    }

    function isValidExpense(data, groupId) {
      return data.amount is number && data.amount > 0 &&
             data.description is string && data.description.size() >= 1 && data.description.size() <= 200 &&
             data.category is string && data.category.size() <= 50 &&
             data.paidBy is string && data.paidBy in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds &&
             data.date is timestamp &&
             data.createdAt == request.time &&
             (data.splitType == null || data.splitType in ['equal', 'percentage', 'exact']);
    }

    function isValidGroupMember(data) {
      return data.uid is string && isValidId(data.uid) &&
             data.role in ['admin', 'member'] &&
             data.joinedAt == request.time &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.email == null || (data.email is string && data.email.size() <= 256));
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      // Deny listing users to prevent PII scraping
      allow list: if false; 
      
      allow create: if isOwner(userId) && 
                       incoming().keys().hasAll(['uid', 'email', 'createdAt']) &&
                       isValidUser(incoming());
                       
      allow update: if isOwner(userId) && 
                       incoming().uid == existing().uid &&
                       incoming().createdAt == existing().createdAt &&
                       isValidUser(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email', 'categoryLimits']);

      match /subscriptions/{subId} {
        allow read: if isOwner(userId) || (isOwner(userId) && resource.data.userId == request.auth.uid);
        
        allow list: if isOwner(userId) || (isOwner(userId) && resource.data.userId == request.auth.uid);
        allow get: if isOwner(userId) || (isOwner(userId) && resource.data.userId == request.auth.uid);
        
        allow create: if isOwner(userId) &&
                         isValidId(subId) &&
                         incoming().keys().hasAll(['name', 'amount', 'cycle', 'nextBillingDate', 'category', 'active', 'userId', 'createdAt']) &&
                         isValidSubscription(incoming());
                         
        allow update: if isOwner(userId) &&
                         incoming().userId == existing().userId &&
                         incoming().createdAt == existing().createdAt &&
                         isValidSubscription(incoming()) &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'amount', 'cycle', 'nextBillingDate', 'category', 'active']);
                         
        allow delete: if isOwner(userId);
      }

      match /savingsGoals/{goalId} {
        allow read: if isOwner(userId) || (isOwner(userId) && resource.data.userId == request.auth.uid);
        
        allow list: if isOwner(userId) || (isOwner(userId) && resource.data.userId == request.auth.uid);
        allow get: if isOwner(userId) || (isOwner(userId) && resource.data.userId == request.auth.uid);
        
        allow create: if isOwner(userId) &&
                         isValidId(goalId) &&
                         incoming().keys().hasAll(['name', 'targetAmount', 'currentAmount', 'color', 'userId', 'createdAt']) &&
                         isValidSavingsGoal(incoming());
                         
        allow update: if isOwner(userId) &&
                         incoming().userId == existing().userId &&
                         incoming().createdAt == existing().createdAt &&
                         isValidSavingsGoal(incoming()) &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'targetAmount', 'currentAmount', 'deadline', 'color']);
                         
        allow delete: if isOwner(userId);
      }
    }

    // Groups
    match /groups/{groupId} {
      // allow get: if isSignedIn() && (request.auth.uid in resource.data.memberIds);
      // Use resource.data for list filtering enforcement
      allow read: if isSignedIn() && (request.auth.uid in resource.data.memberIds);
      
      allow create: if isSignedIn() && 
                       isValidId(groupId) &&
                       incoming().keys().hasAll(['name', 'createdBy', 'type', 'memberIds', 'createdAt']) &&
                       // Check that the creator is the ONLY member initially or at least in the list
                       request.auth.uid in incoming().memberIds &&
                       isValidGroup(incoming());
                       
      allow update: if isSignedIn() && (request.auth.uid in existing().memberIds) &&
                       incoming().createdBy == existing().createdBy &&
                       incoming().createdAt == existing().createdAt &&
                       isValidGroup(incoming()) && (
                         // Action: Update Metadata
                         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'type', 'maxBudget', 'budgetType']) ||
                         // Action: Manage Members (usually handled by separate logic, but whitelisting here for the core list)
                         incoming().diff(existing()).affectedKeys().hasOnly(['memberIds'])
                       );
                       
      allow delete: if isSignedIn() && existing().createdBy == request.auth.uid;

      // Expenses Subcollection
      match /expenses/{expenseId} {
        allow read: if isGroupMember(groupId);
        
        allow create: if isGroupMember(groupId) &&
                         isValidId(expenseId) &&
                         incoming().keys().hasAll(['amount', 'description', 'category', 'paidBy', 'date', 'createdAt']) &&
                         isValidExpense(incoming(), groupId);
                         
        allow update: if isGroupMember(groupId) &&
                         incoming().createdAt == existing().createdAt &&
                         isValidExpense(incoming(), groupId) && (
                           // Only the person who paid or an admin can edit
                           (existing().paidBy == request.auth.uid || isGroupAdmin(groupId)) &&
                           incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'description', 'category', 'paidBy', 'date', 'splitType'])
                         );
                         
        allow delete: if isGroupMember(groupId) && 
                         (existing().paidBy == request.auth.uid || isGroupAdmin(groupId));
      }

      // Members Subcollection
      match /members/{userId} {
        allow read: if isGroupMember(groupId);
        
        allow create: if isSignedIn() &&
                         isValidId(userId) &&
                         incoming().keys().hasAll(['uid', 'role', 'joinedAt']) &&
                         isValidGroupMember(incoming()) && (
                           // First member must be the creator and admin
                           (getAfter(/databases/$(database)/documents/groups/$(groupId)).data.createdBy == request.auth.uid && 
                            userId == request.auth.uid && incoming().role == 'admin') ||
                           // Admins can add others
                           isGroupAdmin(groupId) ||
                           // Users can add themselves if they were invited (added to memberIds list on parent)
                           (userId == request.auth.uid && userId in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds)
                         );
                         
        allow update: if isGroupAdmin(groupId) &&
                         incoming().uid == existing().uid &&
                         incoming().joinedAt == existing().joinedAt &&
                         isValidGroupMember(incoming()) &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName', 'email']);
                         
        allow delete: if isGroupAdmin(groupId) || isOwner(userId);
      }
    }
  }
}

